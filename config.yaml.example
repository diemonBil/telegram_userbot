# Telegram Userbot configuration example
# Copy to config.yaml and fill in your values

# ─── Global Settings ─────────────────────────────────────────────────────────
# Delay range between bot messages (seconds)
delay_min: 8
delay_max: 25

# Number of messages to keep in context window per group
context_window: 30

# ─── Sessions ────────────────────────────────────────────────────────────────
sessions:
  - name: "alex"
    string_session: "1BQANOTEALdXXXXXXXXXXXXXXXXXXXXXXX..."
    is_admin: true          # This session listens for DMs and starts topics
    persona: "Alex, 28 years old, interested in tech and startups. Speaks confidently, sometimes jokes."

  - name: "maria"
    string_session: "1BQANOTEALdYYYYYYYYYYYYYYYYYYYYYYY..."
    is_admin: false
    persona: "Maria, 25 years old, UX/UI designer. Enthusiastic, uses emojis, loves discussing aesthetics."

  - name: "dmytro"
    string_session: "1BQANOTEALdZZZZZZZZZZZZZZZZZZZZZZZ..."
    is_admin: false
    persona: "Dmytro, 32 years old, backend developer. Analytical, replies briefly and to the point."

# ─── Groups ──────────────────────────────────────────────────────────────────
groups:
  - id: -1001234567890       # Telegram group/supergroup ID (negative number)
    username: "test_group"  # ← REPLACE with your group's @username (without @)
    name: "Tech Discussion"
    # Sessions that participate in this group (by name)
    participants: ["alex", "maria", "dmytro"]
    # General prompt for all bots in this group
    prompt: |
      You are a participant in a live chat in a Telegram group about technology and startups.
      Communicate naturally, like a real person: briefly, casually, sometimes with humor.
      Do not use formal phrases, do not remind anyone that you are an AI.
      Stay on topic and be logically consistent.
      Replies should be from 1 to 4 sentences — no more.
